{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 17070
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff"
      },
      {
        "domain_suffix": [
          "ads.doubleclick.net",
          "blocked-demo.example.com"
        ],
        "action": "reject"
      }
    ],
    "final": "direct"
  },
  "services": [
    {
      "type": "api",
      "listen": "127.0.0.1",
      "listen_port": 9095,
      "dashboard": {
        "enabled": true,
        "path": "webui/dist"
      }
    }
  ]
}
