{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": ""
    }
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 17070
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "block",
      "tag": "blocked"
    },
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": ["direct"]
    }
  ],
  "route": {
    "rules": [
      { "action": "sniff" },
      {
        "network": ["tcp", "udp"],
        "action": "route",
        "outbound": "blocked"
      }
    ],
    "final": "blocked"
  },
  "services": [
    {
      "type": "api",
      "listen": "127.0.0.1",
      "listen_port": 9095,
      "dashboard": {
        "enabled": true,
        "path": "webui/dist"
      }
    }
  ]
}
